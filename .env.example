# Copy to .env for local runs (Postgres + Redis on your machine or cloud URLs).
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/quantrisk_db
REDIS_URL=redis://default:PASSWORD@HOST:6379/0
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
ALPHA_VANTAGE_KEY=
ANTHROPIC_API_KEY=
RISK_COMPUTE_INTERVAL_SECONDS=60
LOOKBACK_DAYS=252
VAR_CONFIDENCE_95=0.05
VAR_CONFIDENCE_99=0.01
MARGIN_WARNING_THRESHOLD=0.85
CELERY_BROKER_URL=redis://default:PASSWORD@HOST:6379/0
CELERY_RESULT_BACKEND=redis://default:PASSWORD@HOST:6379/1
METRICS_PORT=9090
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173
ENVIRONMENT=development
